{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id as \"id!\",\n                user_id as \"user_id!\",\n                type as \"type!\",\n                status as \"status!\",\n                title,\n                content,\n                summary,\n                is_flagged,\n                project_id,\n                metadata as \"metadata: _\",\n                source as \"source: _\",\n                external_id as \"external_id: _\",\n                created_at,\n                updated_at,\n                deleted_at\n            FROM notes\n            WHERE (deleted_at IS NOT NULL) = $1\n              AND ($2::text IS NULL OR type = $2)\n              AND ($3::uuid IS NULL OR project_id = $3)\n            ORDER BY created_at DESC\n            LIMIT $4\n            ",
